name: "Security: Checkmarx Scan (SAST, SCA, Container)"
 
on:
  push:
    branches: [ "master", "release/*","feature/demo_checkmarx" ]
    paths:
      - "**"
  pull_request:
    types: [opened, synchronize, reopened]
    branches: [ "master", "release/*" , "feature/demo_checkmarx" ]
# env:
#   DAY_OF_WEEK: Monday
permissions:
  contents: read
  security-events: write  # For uploading SARIF results
 
jobs:
  checkmarx-security-scan:
    runs-on: ubuntu-22.04
    environment: Develop
    concurrency:
      group: checkmarx-security-${{ github.workflow }}-${{ github.ref }}
      cancel-in-progress: true
 
    steps:
      - name: Checkout
        uses: actions/checkout@v4
 
      # =====================================
      # Install Checkmarx One CLI
      # =====================================
      - name: Install Checkmarx One CLI
        run: |
          echo "Downloading Checkmarx One CLI..."
          curl -L https://github.com/Checkmarx/ast-cli/releases/latest/download/ast-cli_linux_x64.tar.gz -o ast-cli.tar.gz
          tar -xf ast-cli.tar.gz
          chmod +x cx
          sudo mv cx /usr/local/bin/
          echo "Checkmarx CLI installed successfully"
          cx version
### image
      - name: Configure Checkmarx CLI
        env:
          CX_APIKEY: ${{ secrets.CX_APIKEY }}
          CX_BASE_URI: ${{ secrets.CX_BASE_URI }}
          CX_TENANT: ${{ secrets.CX_TENANT }}
        run: |
          echo "Configuring Checkmarx CLI..."
          echo "Checkmarx configured via environment variables"
 
      # =====================================
      # 1. SAST - Checkmarx SAST Scan
      # =====================================
      - name: Checkmarx SAST scan
        id: cx_sast
        continue-on-error: true
        env:
          CX_APIKEY: ${{ secrets.CX_APIKEY }}
          CX_BASE_URI: ${{ secrets.CX_BASE_URI }}
          CX_TENANT: ${{ secrets.CX_TENANT }}
        run: |
          EXIT_CODE=0
          echo "🔍 Starting Checkmarx SAST scan..."
          echo "Repository: ${{ github.repository }}"
          echo "Branch: ${{ github.ref_name }}"
          echo ""
 
          # Use incremental only on pull_request (not on first scan / new branch)
          INCREMENTAL_FLAG=""
          if [ "${{ github.event_name }}" == "pull_request" ]; then
            INCREMENTAL_FLAG="--incremental"
          fi
 
          cx scan create \
            --project-name "${{ github.repository }}" \
            --branch "${{ github.ref_name }}" \
            --scan-types sast \
            $INCREMENTAL_FLAG \
            --threshold "sast-high=1" \
            --report-format json \
            --output-name sast-results \
            --output-path ./ \
            -s . \
            || EXIT_CODE=$?
 
          echo ""
          if [ $EXIT_CODE -eq 0 ]; then
            echo "SAST: No HIGH severity issues found"
          else
            echo "SAST: HIGH severity issues detected"
          fi
 
          echo "sast_exit_code=${EXIT_CODE}" >> "$GITHUB_OUTPUT"
 
      - name: Upload SAST Results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: checkmarx-sast-results
          path: sast-results.json
          retention-days: 7
          if-no-files-found: warn
 
      # =====================================
      # 2. SCA - Software Composition Analysis
      # =====================================
      - name: Checkmarx SCA scan
        id: cx_sca
        continue-on-error: true
        env:
          CX_APIKEY: ${{ secrets.CX_APIKEY }}
          CX_BASE_URI: ${{ secrets.CX_BASE_URI }}
          CX_TENANT: ${{ secrets.CX_TENANT }}
        run: |
          EXIT_CODE=0
          echo "Starting Checkmarx SCA scan..."
          echo ""
 
          INCREMENTAL_FLAG=""
          if [ "${{ github.event_name }}" == "pull_request" ]; then
            INCREMENTAL_FLAG="--incremental"
          fi
 
          cx scan create \
            --project-name "${{ github.repository }}" \
            --branch "${{ github.ref_name }}" \
            --scan-types sca \
            $INCREMENTAL_FLAG \
            --threshold "sca-high=1" \
            --report-format json \
            --output-name sca-results \
            --output-path ./ \
            -s . \
            || EXIT_CODE=$?
 
          echo ""
          if [ $EXIT_CODE -eq 0 ]; then
            echo "SCA: No HIGH severity vulnerabilities found"
          else
            echo "SCA: HIGH severity vulnerabilities detected"
          fi
 
          echo "sca_exit_code=${EXIT_CODE}" >> "$GITHUB_OUTPUT"
 
      - name: Upload SCA Results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: checkmarx-sca-results
          path: sca-results.json
          retention-days: 7
          if-no-files-found: warn
 
      # =====================================
      # 3. Container Image Scan (KICS)
      # =====================================
      - name: Check for Dockerfile
        id: dockerfile_check
        run: |
          if [ -f "Dockerfile" ]; then
            echo "has_dockerfile=true" >> "$GITHUB_OUTPUT"
            echo "Dockerfile found"
          else
            echo "has_dockerfile=false" >> "$GITHUB_OUTPUT"
            echo "No Dockerfile found, container scanning will be skipped"
          fi
 
      - name: Checkmarx Container scan (KICS)
        id: cx_container
        if: steps.dockerfile_check.outputs.has_dockerfile == 'true'
        continue-on-error: true
        env:
          CX_APIKEY: ${{ secrets.CX_APIKEY }}
          CX_BASE_URI: ${{ secrets.CX_BASE_URI }}
          CX_TENANT: ${{ secrets.CX_TENANT }}
        run: |
          EXIT_CODE=0
          echo "Starting Checkmarx KICS (IaC) scan..."
          echo ""
 
          INCREMENTAL_FLAG=""
          if [ "${{ github.event_name }}" == "pull_request" ]; then
            INCREMENTAL_FLAG="--incremental"
          fi
 
          cx scan create \
            --project-name "${{ github.repository }}" \
            --branch "${{ github.ref_name }}" \
            --scan-types kics \
            $INCREMENTAL_FLAG \
            --threshold "kics-high=1" \
            --report-format json \
            --output-name kics-results \
            --output-path ./ \
            -s . \
            || EXIT_CODE=$?
 
          echo ""
          if [ $EXIT_CODE -eq 0 ]; then
            echo "Container/IaC: No HIGH severity issues found"
          else
            echo "Container/IaC: HIGH severity issues detected"
          fi
 
          echo "container_exit_code=${EXIT_CODE}" >> "$GITHUB_OUTPUT"
 
      - name: Upload Container Results
        if: always() && steps.dockerfile_check.outputs.has_dockerfile == 'true'
        uses: actions/upload-artifact@v4
        with:
          name: checkmarx-kics-results
          path: kics-results.json
          retention-days: 7
          if-no-files-found: warn
 
      # =====================================
      # Summary Report
      # =====================================
      - name: Security Scan Summary
        if: always()
        run: |
          echo "================================"
          echo "   Security Scan Summary        "
          echo "================================"
          echo ""
          echo "Repository: ${{ github.repository }}"
          echo "Branch:     ${{ github.ref_name }}"
          echo "Commit:     ${{ github.sha }}"
          echo ""
          echo "Scan Results:"
          echo "-------------"
 
          # SAST
          if [ "${{ steps.cx_sast.outputs.sast_exit_code }}" == "0" ]; then
            echo "SAST (Code): No HIGH severity issues"
          else
            echo "SAST (Code): HIGH severity issues detected"
          fi
 
          # SCA
          if [ "${{ steps.cx_sca.outputs.sca_exit_code }}" == "0" ]; then
            echo "SCA (Dependencies): No HIGH severity vulnerabilities"
          else
            echo "SCA (Dependencies): HIGH severity vulnerabilities detected"
          fi
 
          # Container/KICS
          if [ "${{ steps.dockerfile_check.outputs.has_dockerfile }}" == "true" ]; then
            if [ "${{ steps.cx_container.outputs.container_exit_code }}" == "0" ]; then
              echo "KICS (IaC/Container): No HIGH severity issues"
            else
              echo "KICS (IaC/Container): HIGH severity issues detected"
            fi
          else
            echo "KICS (IaC/Container): No Dockerfile found, skipped"
          fi
 
          echo ""
          echo "View detailed results at:"
          echo "   Checkmarx Dashboard: ${{ secrets.CX_BASE_URI }}"
          echo ""
          echo "Download artifacts from this workflow run for detailed reports"
 
      # =====================================
      # Fail on HIGH severity (uncomment to enable)
      # =====================================
      - name: Fail on HIGH severity issues
        if: always()
        run: |
          SHOULD_FAIL=false
     
          if [ "${{ steps.cx_sast.outputs.sast_exit_code }}" != "0" ]; then
            echo "❌ SAST found HIGH severity issues"
            SHOULD_FAIL=true
          fi
     
          if [ "${{ steps.cx_sca.outputs.sca_exit_code }}" != "0" ]; then
            echo "❌ SCA found HIGH severity vulnerabilities"
            SHOULD_FAIL=true
          fi
     
          if [ "${{ steps.dockerfile_check.outputs.has_dockerfile }}" == "true" ]; then
            if [ "${{ steps.cx_container.outputs.container_exit_code }}" != "0" ] && \
               [ -n "${{ steps.cx_container.outputs.container_exit_code }}" ]; then
              echo "❌ KICS scan found HIGH severity issues"
              SHOULD_FAIL=true
            fi
          fi
     
          if [ "$SHOULD_FAIL" == "true" ]; then
            echo ""
            echo "🔍 Review findings at: ${{ secrets.CX_BASE_URI }}"
            echo "📥 Download result artifacts for detailed analysis"
            exit 1
          else
            echo "✅ All security scans passed"
          fi